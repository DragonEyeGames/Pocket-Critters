[resource]
script = ExtResource("1_knn6a")
trainerName = "Professor"
preFightDialogue = Array[String](["Howdy youngin'!", "I am here to help you step into your new life.", "Like most kids your age it appears that you left home to learn about the world!", "Thankfully, there are lots of amazing thing to learn about the world and the critters within!", "And I will help you do it safely, which is the most imporant thing to remember. Saftey first!", "First off, whats your name?"])
afterFightDialogue = Array[String](["Allright first lesson. In the tall grass you can get attacked by wild critters!", "Fend them off with your own critters or try to catch them!", "If a trainer catches sight of you they might initiate a battle!", "You can't catch their critters or run away, so the strongest wins!", "That should be it.", "Have a nice journey and I hope we meet again!"])
sprite = "M6"
metadata/_custom_type_script = "uid://0mhfdoexj3v2"
