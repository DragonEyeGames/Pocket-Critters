; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pocket Critters"
run/main_scene="uid://b07drnf5qheia"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://Assets/icon.svg"

[autoload]

GameManager="*res://Scripts/GameManager.gd"
SignalBus="*res://Scripts/SignalBus.gd"
Music="*res://Scenes/music.tscn"
Stats="*res://Scenes/stats.tscn"
Info="*res://Scenes/info.tscn"
PokedexText="*res://Scripts/pokedexText.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=3
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[file_customization]

folder_colors={
"res://Levels/": "green",
"res://Moves/MediumMoves/": "orange",
"res://Moves/StrongMoves/": "yellow",
"res://Moves/WeakMoves/": "red",
"res://Music/": "purple"
}

[global_group]

Y-Sort=""
Grass=""

